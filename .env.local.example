# Copy to .env.local and fill in. Never commit .env.local.

# Supabase (Auth, Postgres, Storage)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only (RLS bypass for trusted server actions / migrations helpers)
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (AI editing suggestions, scripts) — uses latest Claude models
ANTHROPIC_API_KEY=

# Transcription (speech-to-text, word-level timestamps) — Phase 2
# e.g. Deepgram / AssemblyAI / a Whisper-based provider
TRANSCRIPTION_API_KEY=

# Captions / TTS / noise removal providers — Phase 4+ (optional/stretch)
CAPTIONS_API_KEY=
