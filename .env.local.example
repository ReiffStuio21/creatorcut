# Copy to .env.local and fill in. Never commit .env.local.

# Supabase (Auth, Postgres, Storage)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only (RLS bypass for trusted server actions / migrations helpers)
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (AI editing suggestions, scripts) — uses latest Claude models
ANTHROPIC_API_KEY=

# Transcription (speech-to-text, word-level timestamps)
# Set BOTH to enable real transcription (Deepgram). Without these, the app uses
# a built-in dev mock so the editor works with zero config.
#   1) the server-side key:
DEEPGRAM_API_KEY=
#   (TRANSCRIPTION_API_KEY is also accepted as an alias for the key)
TRANSCRIPTION_API_KEY=
#   2) the public flag that tells the client to extract + send audio:
NEXT_PUBLIC_TRANSCRIPTION_ENABLED=

# Captions / TTS / noise removal providers — Phase 4+ (optional/stretch)
CAPTIONS_API_KEY=
